{
  "expo": {
    "name": "Cutloon",
    "slug": "cutloon-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-logo-dummy.png",
    "scheme": "cutloonapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.cutloonapp"
    },
    "android": {
      "versionCode":2,
      "icon": "./assets/images/app-logo-dummy.png",  
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.cutloonapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-dummy.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Cutloon to access your camera for capturing images and videos.",
          "microphonePermission": "Allow Cutloon to access your microphone when recording video."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Cutloon to access your location when booking salon appointments."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
